<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <!-- 控制台输出：本项目开发阶段先统一输出到控制台，便于 IDEA 和 Tomcat 查看日志。 -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%t] %c{1.} - %msg%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <!-- 项目自身代码打开 debug，便于开发阶段观察 Controller、Service、Mapper 调用。 -->
        <Logger name="com.fishshop" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <!-- 第三方依赖默认 info，减少控制台噪声。 -->
        <Root level="info">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
