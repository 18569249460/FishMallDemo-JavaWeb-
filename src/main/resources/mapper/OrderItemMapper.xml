<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fishshop.mapper.OrderItemMapper">
    <!-- 订单商品快照映射：即使商品后续改名、改价或删除，历史订单仍保留当时数据。 -->
    <resultMap id="OrderItemResultMap" type="com.fishshop.entity.OrderItem">
        <id property="id" column="id"/>
        <result property="orderId" column="order_id"/>
        <result property="productId" column="product_id"/>
        <result property="productName" column="product_name"/>
        <result property="price" column="price"/>
        <result property="quantity" column="quantity"/>
        <result property="subtotal" column="subtotal"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 查询某个订单下的全部商品明细。 -->
    <select id="selectByOrderId" resultMap="OrderItemResultMap">
        SELECT id, order_id, product_id, product_name, price, quantity, subtotal, created_at
        FROM order_item
        WHERE order_id = #{orderId}
        ORDER BY id ASC
    </select>

    <!-- 创建订单时批量写入商品快照，必须和订单主表、扣库存处于同一事务。 -->
    <insert id="insertBatch">
        INSERT INTO order_item (order_id, product_id, product_name, price, quantity, subtotal)
        VALUES
        <foreach collection="items" item="item" separator=",">
            (#{item.orderId}, #{item.productId}, #{item.productName}, #{item.price}, #{item.quantity}, #{item.subtotal})
        </foreach>
    </insert>
</mapper>
