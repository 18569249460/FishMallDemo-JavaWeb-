<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fishshop.mapper.UserMapper">
    <!-- 用户表映射：字段名带下划线，Java 属性使用驼峰命名。 -->
    <resultMap id="UserResultMap" type="com.fishshop.entity.User">
        <id property="id" column="id"/>
        <result property="avatar" column="avatar"/>
        <result property="nickname" column="nickname"/>
        <result property="phone" column="phone"/>
        <result property="password" column="password"/>
        <result property="role" column="role"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 用户基础字段清单：复用后避免多个查询字段不一致。 -->
    <sql id="BaseColumns">
        id, avatar, nickname, phone, password, role, status, created_at, updated_at
    </sql>

    <!-- 按主键查询用户，常用于 Token 解析后获取当前用户信息。 -->
    <select id="selectById" resultMap="UserResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM `user`
        WHERE id = #{id}
    </select>

    <!-- 按手机号查询用户，登录和注册唯一性校验都会用到。 -->
    <select id="selectByPhone" resultMap="UserResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM `user`
        WHERE phone = #{phone}
    </select>

    <!-- 管理端用户列表，按最新注册倒序展示。 -->
    <select id="selectAll" resultMap="UserResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM `user`
        ORDER BY id DESC
    </select>

    <!-- 注册用户，主键由数据库自增并回填到实体。 -->
    <insert id="insert" parameterType="com.fishshop.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `user` (avatar, nickname, phone, password, role, status)
        VALUES (#{avatar}, #{nickname}, #{phone}, #{password}, #{role}, #{status})
    </insert>

    <!-- 启用/禁用普通用户；管理员账号不允许通过页面误操作禁用。 -->
    <update id="updateStatus">
        UPDATE `user`
        SET status = #{status}
        WHERE id = #{id}
          AND role != 1
    </update>

    <!-- 当前用户修改昵称和头像。 -->
    <update id="updateProfile" parameterType="com.fishshop.entity.User">
        UPDATE `user`
        SET nickname = #{nickname},
            avatar = #{avatar}
        WHERE id = #{id}
    </update>

    <!-- 后台仪表盘统计用户总数。 -->
    <select id="countAll" resultType="long">
        SELECT COUNT(1) FROM `user`
    </select>
</mapper>
